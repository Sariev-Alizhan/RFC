# === Уведомления менеджерам в Telegram ===
# Секрет для серверного эндпоинта RFC (тот же, что WA_BOT_SECRET в Vercel).
WA_BOT_SECRET=
# URL эндпоинта (по умолчанию прод). Обычно менять не нужно.
NOTIFY_URL=https://redflag.kz/api/tg/notify-order

# === AI-часть продажника (Claude). Без ключа — чисто сценарный режим. ===
# Ключ: https://console.anthropic.com → API Keys
CLAUDE_API_KEY=
# Модель (по умолчанию дешёвая Haiku 4.5). Можно claude-sonnet-4-6 для качества.
CLAUDE_MODEL=claude-haiku-4-5-20251001
